# Copy to `.env` and fill in real values for anything sensitive.
# `.env` is gitignored; `.env.example` is the committed template.
# docker-compose.yml reads these automatically; Spring reads them via
# `spring-dotenv` for `local` runs and via the host env in `docker`/`prod`.

# ---------- Postgres ----------
# Superuser — only used for administration / init script. App services
# connect as their own per-DB user below.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Per-service database passwords (usernames are fixed: userdb_user, etc.).
USERDB_PASSWORD=userdb_pass
PRODUCTDB_PASSWORD=productdb_pass
ORDERDB_PASSWORD=orderdb_pass

# ---------- RabbitMQ ----------
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ---------- pgAdmin ----------
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=admin

# ---------- Security ----------
# HMAC secret for JWT signing/validation — shared across services (decision #5).
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string-at-least-256-bits

# ---------- Platform services (Phase 2) ----------
# All optional for local dev — defaults in each service's application.yml target localhost.
# Override for docker-compose (service DNS names) or a remote environment.

# config-service
# SPRING_PROFILES_ACTIVE=native            # `native` (default) or `git`
# CONFIG_REPO_URI=file:///config-repo      # used only when SPRING_PROFILES_ACTIVE=git
# CONFIG_REPO_BRANCH=main

# Clients of config-service (e.g. user-service)
# CONFIG_SERVER_URI=http://localhost:8888

# discovery-service / eureka clients
# EUREKA_HOSTNAME=localhost
# EUREKA_URI=http://localhost:8761/eureka

# Cloud Bus / AMQP connection (host + port; creds reuse RABBITMQ_USER/PASSWORD above)
# RABBITMQ_HOST=localhost
# RABBITMQ_PORT=5672